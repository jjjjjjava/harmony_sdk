{
  "apiType": "stageMode",
  "buildOption": {
    "napiLibFilterOption": {
      "excludes": [
        "**/armeabi-v7a/**",
        "**/x86_64/**"
      ]
    }
  },
  "buildOptionSet": [
    {
      "name": "release",
      "arkOptions": {
        "obfuscation": {
          "ruleOptions": {
            "enable": false,
            "files": [
              "./obfuscation-rules.txt"
            ]
          }
        }
      }
    },
  ],
  "targets": [
    {
      "name": "default"
    },
    {
      "name": "ohosTest",
    }
  ]
}